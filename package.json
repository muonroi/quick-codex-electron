{
  "name": "@quick-codex/qc-electron",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Minimal Electron host for Codex native TUI with an input/output interception boundary.",
  "main": "main.mjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muonroi/quick-codex-electron.git"
  },
  "scripts": {
    "vendor": "node ./scripts/vendor.mjs",
    "postinstall": "node ./scripts/vendor.mjs",
    "dev": "node ./scripts/run-electron.mjs",
    "dev:xvfb": "xvfb-run -a npm run dev",
    "smoke:xvfb": "QUICK_CODEX_ELECTRON_SMOKE_EXIT_MS=3000 xvfb-run -a npm run dev",
    "start": "node ./scripts/run-electron.mjs"
  },
  "dependencies": {
    "electron": "^31.2.0",
    "node-pty": "^1.0.0",
    "quick-codex": "file:../quick-codex",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
